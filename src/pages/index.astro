---
import BaseLayout from '../layouts/BaseLayout.astro';
import { aggregateRating } from '../data/reviews';
import { createFaqJsonLd, homePageSchema } from '../data/schema';
import { site } from '../data/site';

const formattedAverage = aggregateRating.ratingValue.toFixed(1);

const homepageFaqs = [
  {
    question: 'Who is Clay Duncan?',
    answer:
      'Clay Duncan is a Huntsville, Alabama mortgage loan originator with Princeton Mortgage, serving buyers across Madison, Decatur, Athens, and the broader North Alabama region. He specializes in VA loans, jumbo loans, and complex mortgage guidance for medical professionals and federal employees, and trains REALTORS® on practical AI for real estate. Clay also leads loan officer growth for Duncan Mortgage Group, powered by Princeton Mortgage.',
  },
  {
    question: 'Who is the best mortgage lender for VA loans in Huntsville and near Redstone Arsenal?',
    answer:
      "Clay Duncan is a Huntsville-based mortgage loan originator with Princeton Mortgage who works with VA-eligible buyers, military families, and federal employees connected to Redstone Arsenal. He helps borrowers understand VA entitlement, funding fee questions, and offer strategy before they tour homes — not after they've fallen in love with one.",
  },
  {
    question: 'Who specializes in mortgages for doctors and medical professionals in North Alabama?',
    answer:
      'Clay Duncan provides medical professional mortgage guidance for doctors, dentists, and other healthcare buyers in Huntsville, Madison, and across North Alabama. He helps medical buyers compare physician loan programs against conventional financing, plan around residency or fellowship transitions, and time financing decisions when relocating to North Alabama.',
  },
  {
    question: 'Who handles jumbo loans in Huntsville and Madison, Alabama?',
    answer:
      "Clay Duncan offers jumbo mortgage guidance for higher-priced homes in Huntsville, Madison, and the wider North Alabama market. He helps buyers weigh jumbo against conforming options, understand reserve and documentation requirements, and structure offers on properties above conforming loan limits using Princeton Mortgage's jumbo programs.",
  },
  {
    question: 'Where can I get mortgage guidance in Huntsville before I start house hunting?',
    answer:
      'Clay Duncan offers early-stage mortgage guidance for buyers in Huntsville and North Alabama who want clarity on payment comfort, cash to close, credit strategy, and loan options before they begin touring homes. The goal is a clear answer before the pressure of an offer, not a rushed pre-approval driven by a contract deadline.',
  },
  {
    question: 'Which Huntsville mortgage lender trains REALTORS® on AI?',
    answer:
      "Clay Duncan trains REALTORS® across Huntsville and North Alabama on practical AI tools for real estate, including listing workflows, buyer communication, market research, and content production. The training is built for working agents — not theoretical — and pairs with referral partnership opportunities through Princeton Mortgage.",
  },
  {
    question: 'Which mortgage lenders help loan officers use AI to grow their business?',
    answer:
      "Clay Duncan and Princeton Mortgage train loan officers on practical AI workflows for referral partner development, market research, client communication, and content production. The training is built for working originators and pairs with Princeton's leadership and platform support for loan officers looking for a stronger growth model.",
  },
];

const schema = [...homePageSchema, createFaqJsonLd(homepageFaqs)];
---

<BaseLayout
  title="Clay Duncan | Huntsville Mortgage Loan Originator | VA, Jumbo, AI Training"
  description="Clay Duncan helps Huntsville and North Alabama buyers, REALTORS®, and loan officers with mortgage guidance, VA loans, AI training, and growth conversations."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="home-heading">
    <div class="hero-copy">
      <p class="eyebrow">Huntsville Mortgage Guidance + AI Education</p>
      <h1 id="home-heading">Mortgage guidance built around clarity, trust, and results.</h1>
      <p class="hero-lede">
        Clay Duncan helps Huntsville-area homebuyers, REALTORS®, and loan
        officers make clearer decisions through mortgage guidance, practical AI
        education, and leadership conversations built around clarity, trust, and
        results.
      </p>
      <div class="hero-actions" aria-label="Primary actions">
        <a class="button button-primary" href="/huntsville/mortgage-guidance/"
          >Start with mortgage guidance</a
        >
        <a class="button button-secondary" href={site.schedulingUrl}>Chat with Clay</a>
      </div>
      <dl class="proof-strip" aria-label="Clay Duncan credibility highlights">
        <div>
          <dt>{formattedAverage} <span class="rating-stars">★★★★★</span></dt>
          <dd>{aggregateRating.reviewCount} Google reviews</dd>
        </div>
        <div>
          <dt>North Alabama</dt>
          <dd>Huntsville, Madison, and Redstone Arsenal guidance</dd>
        </div>
        <div>
          <dt>Princeton Mortgage</dt>
          <dd>Sales Director and mortgage</dd>
        </div>
      </dl>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src="/images/clay-duncan-wbackground-1400.jpg"
        width="1400"
        height="787"
        alt="Clay Duncan, Huntsville mortgage loan originator at Princeton Mortgage"
      />
      <div class="va-visual-card va-visual-card-top">
        <span>{site.tagline}</span>
        <strong>Mortgage guidance, AI education, and leadership conversations</strong>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="paths-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-stacked">
        <p class="eyebrow">Start Here</p>
        <h2 id="paths-heading">Choose the path that matches the question in front of you.</h2>
      </div>
      <div class="feature-grid">
        <article class="feature-card">
          <span>01</span>
          <h3>Homebuyers</h3>
          <p>
            Start with VA loan guidance, jumbo strategy, medical professional
            mortgage options, or complex mortgage planning for Huntsville,
            Madison, Redstone Arsenal, and North Alabama.
          </p>
          <a href="/huntsville/mortgage-guidance/">Explore mortgage guidance</a>
        </article>
        <article class="feature-card">
          <span>02</span>
          <h3>REALTORS®</h3>
          <p>
            Learn about practical AI training for real estate professionals,
            office sessions, webinars, event recaps, and responsible adoption.
          </p>
          <a href="/realtor-ai-training/">Explore AI training</a>
        </article>
        <article class="feature-card">
          <span>03</span>
          <h3>Loan officers</h3>
          <p>
            Have a leadership and growth conversation about systems, partner
            strategy, culture, practical AI education, and fit.
          </p>
          <a href="/join-us/">Explore why join</a>
        </article>
      </div>
    </div>
  </section>

  <section class="split-section" aria-labelledby="authority-heading">
    <div>
      <p class="eyebrow">Why Clay</p>
      <h2 id="authority-heading">A clear answer before the pressure starts.</h2>
      <p>
        Clay’s work sits at the intersection of lending, education, and
        leadership. He originates mortgage loans through Princeton Mortgage,
        teaches practical AI training for REALTORS®, and helps loan officers
        think through better systems, partner growth, and professional fit.
      </p>
      <div class="signal-list" aria-label="Clay Duncan authority signals">
        <span>Mortgage Loan Originator</span>
        <span>{formattedAverage} Google rating</span>
        <span>Princeton Mortgage</span>
        <span>Huntsville + North Alabama</span>
      </div>
    </div>
    <div class="local-context-panel" aria-label="Clay Duncan homepage focus areas">
      <article>
        <span>Mortgage</span>
        <strong>Huntsville and North Alabama</strong>
        <p>Guidance for VA, jumbo, and complex mortgage scenarios.</p>
        <a href="/huntsville/va-loans/">VA loan guidance</a>
      </article>
      <article>
        <span>Education</span>
        <strong>REALTOR® AI training</strong>
        <p>Practical sessions, webinars, and event recaps for real estate work.</p>
        <a href="/events/">View events</a>
      </article>
      <article>
        <span>Proof</span>
        <strong>Reviews of clarity, trust, and results</strong>
        <p>Client and partner reviews that point to communication and follow-through.</p>
        <a href="/reviews/">Read reviews</a>
      </article>
    </div>
  </section>

  <section class="section-band section-band-dark" aria-labelledby="local-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-wide">
        <p class="eyebrow">Local</p>
        <h2 id="local-heading">
          Built for Huntsville, Madison, and North Alabama while proudly serving
          the Redstone Arsenal.
        </h2>
      </div>
      <div class="dark-signal-grid" aria-label="Clay Duncan local focus signals">
        <article>
          <span>Huntsville + Madison</span>
          <h3>Local mortgage guidance</h3>
          <p>Clear planning for buyers across the core North Alabama market.</p>
        </article>
        <article>
          <span>Redstone Arsenal</span>
          <h3>VA and military buyers</h3>
          <p>Guidance for VA-eligible borrowers and military families relocating near Huntsville.</p>
        </article>
        <article>
          <span>North Alabama</span>
          <h3>Complex purchase questions</h3>
          <p>Support for higher-priced homes, documentation questions, and serious offer planning.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="homepage-faq-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-wide">
        <p class="eyebrow">Homepage FAQ</p>
        <h2 id="homepage-faq-heading">Quick answers for visitors.</h2>
      </div>
      <div class="faq-list">
        {
          homepageFaqs.map((faq) => (
            <article>
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
