---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  createBreadcrumbJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  personJsonLd,
} from '../data/schema';
import { site } from '../data/site';

const schema = [
  personJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Contact', path: '/contact/' },
  ]),
];
---

<BaseLayout
  title="Contact Clay Duncan | Huntsville Mortgage Guidance"
  description="Contact Clay Duncan for mortgage guidance, AI training, REALTOR® support, or a real conversation about your next step."
  schema={schema}
>
  <section class="hero-section hero-section-compact" aria-labelledby="contact-heading">
    <div class="hero-copy">
      <p class="eyebrow">Contact</p>
      <h1 id="contact-heading">Let’s have a real conversation.</h1>
      <p class="hero-lede">
        Reach out for mortgage guidance, AI training, REALTOR® support, or a
        conversation about your next professional chapter.
      </p>
    </div>
    <div class="contact-panel">
      <h2>Talk with Clay</h2>
      <p>
        <a href={site.phoneHref}>{site.phone}</a>
        <a href={site.emailHref}>{site.email}</a>
      </p>
      <p>
        Clay Duncan, Mortgage Loan Originator, NMLS #{site.nmlsId}. Serving
        Huntsville, Madison, Redstone Arsenal, and North Alabama through
        Princeton Mortgage.
      </p>
      <a class="button button-primary" href={site.schedulingUrl}>
        Schedule a conversation
      </a>
    </div>
  </section>
</BaseLayout>
