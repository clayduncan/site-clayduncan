---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  createBreadcrumbJsonLd,
  createFaqJsonLd,
  defaultSchemaImage,
  organizationJsonLd,
  professionalServiceJsonLd,
  personJsonLd,
} from '../../data/schema';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: {
      slug: post.id.replace(/\.mdx?$/, '').replace(/\/index$/, ''),
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const slug = post.id.replace(/\.mdx?$/, '').replace(/\/index$/, '');
const pagePath = `/blog/${slug}/`;
const pageUrl = new URL(pagePath, site.url).href;
const pageTitle =
  post.data.metaTitle ??
  (slug === 'how-realtors-can-use-ai-without-losing-the-human-side-of-real-estate'
    ? 'AI for REALTORS® Without Losing the Human Side | Clay Duncan'
    : `${post.data.title} | Clay Duncan`);
const pageImage = post.data.ogImage
  ? new URL(post.data.ogImage, site.url).href
  : defaultSchemaImage;
const pageDescription = post.data.description;
const socialDescription = post.data.ogDescription ?? pageDescription;
const modifiedDate = post.data.updatedDate ?? post.data.publishDate;

const categoryLabels = {
  'ai-for-realtors': 'AI for REALTORS®',
  'events-recaps': 'Events & Recaps',
  'mortgage-strategy': 'Mortgage Strategy',
  'loan-officer-growth': 'Loan Officer Growth',
} as const;

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
});

const articleAbout = [
  categoryLabels[post.data.category],
  ...post.data.tags,
].filter((item, index, items) => items.indexOf(item) === index);

const schema = [
  personJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    '@id': `${pageUrl}#article`,
    url: pageUrl,
    headline: post.data.title,
    description: post.data.schemaDescription ?? post.data.description,
    image: pageImage,
    datePublished: post.data.publishDate.toISOString().slice(0, 10),
    dateModified: modifiedDate.toISOString().slice(0, 10),
    author: {
      '@type': 'Person',
      name: post.data.author,
      url: `${site.url}/about/`,
    },
    publisher: {
      '@type': 'Organization',
      name: 'Team Duncan',
      logo: {
        '@type': 'ImageObject',
        url: `${site.url}/brand-assets/duncan-d-mark-512.png`,
      },
    },
    mainEntityOfPage: pageUrl,
    about: [
      ...articleAbout.map((tag) => ({ '@type': 'Thing', name: tag })),
    ],
  },
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Blog', path: '/blog/' },
    { name: post.data.title, path: pagePath },
  ]),
  ...(post.data.faqs.length > 0 ? [createFaqJsonLd(post.data.faqs)] : []),
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={pageUrl}
  robots="index, follow"
  ogTitle={post.data.ogTitle ?? `${post.data.title} | Clay Duncan`}
  ogDescription={socialDescription}
  ogImage={pageImage}
  twitterCard={post.data.ogImage ? 'summary_large_image' : 'summary'}
  twitterTitle={post.data.ogTitle ?? `${post.data.title} | Clay Duncan`}
  twitterDescription={socialDescription}
  twitterImage={pageImage}
  ogType="article"
  schema={schema}
>
  <article class="article-page">
    <header class="article-header">
      <p class="eyebrow">{categoryLabels[post.data.category]}</p>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="article-meta">
        <span>By <a href="/about/">{post.data.author}</a></span>
        <span>Published {dateFormatter.format(post.data.publishDate)}</span>
        <span>Updated {dateFormatter.format(modifiedDate)}</span>
      </div>
    </header>
    {
      post.data.ogImage && (
        <img
          class="article-featured-image"
          src={post.data.ogImage}
          width="1200"
          height="630"
          alt={
            post.data.ogImageAlt ??
            `Featured image for ${post.data.title}`
          }
        />
      )
    }
    <div class="article-body">
      <Content />
    </div>
    <footer class="article-footer">
      <a class="button button-primary" href={site.schedulingUrl}>Chat with Clay</a>
      <a class="button button-secondary" href="/blog/">Back to blog</a>
    </footer>
  </article>
</BaseLayout>
