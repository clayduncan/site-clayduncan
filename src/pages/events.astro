---
import BaseLayout from '../layouts/BaseLayout.astro';
import { events, pastEvents, upcomingEvents } from '../data/events';
import {
  createBreadcrumbJsonLd,
  createEventJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  personJsonLd,
} from '../data/schema';
import { site } from '../data/site';

const pagePath = '/events/';
const pageUrl = new URL(pagePath, site.url).href;

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  weekday: 'short',
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

const formatDate = (date: string) =>
  dateFormatter.format(new Date(`${date}T12:00:00`));

const schema = [
  personJsonLd,
  organizationJsonLd,
  professionalServiceJsonLd,
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: 'Clay Duncan Events',
    description:
      'Upcoming and past AI training events from Clay Duncan for REALTORS®, teams, mortgage professionals, and homebuyers.',
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: events.map((event, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        item: { '@id': `${site.url}/events/#${event.date}` },
      })),
    },
    isPartOf: { '@id': `${site.url}/#website` },
    about: [
      { '@type': 'Thing', name: 'AI training for REALTORS®' },
      { '@type': 'Thing', name: 'Princeton Mortgage AI training' },
      { '@type': 'Thing', name: 'real estate AI education' },
      { '@type': 'Place', name: 'Huntsville, Alabama' },
      { '@type': 'Place', name: 'North Alabama' },
    ],
  },
  ...events.map((event) => createEventJsonLd(event)),
  createBreadcrumbJsonLd([
    { name: 'Home', path: '/' },
    { name: 'Events', path: pagePath },
  ]),
];
---

<BaseLayout
  title="Events | AI Training with Clay Duncan"
  description="View upcoming and past Clay Duncan AI training events for REALTORS®, real estate teams, mortgage professionals, and homebuyers."
  schema={schema}
>
  <section class="hero-section landing-hero va-landing-hero" aria-labelledby="events-heading">
    <div class="hero-copy">
      <p class="eyebrow">Events</p>
      <h1 id="events-heading">AI training events built for real work.</h1>
      <p class="hero-lede">
        Clay Duncan teaches practical AI sessions for REALTORS®, real estate
        offices, mortgage professionals, and homebuyers who want useful systems
        without losing the human part of the work.
      </p>
      <div class="hero-actions" aria-label="Event page actions">
        <a class="button button-primary" href={site.schedulingUrl}>Ask about hosting a session</a>
        <a class="button button-secondary" href="/realtor-ai-training/">Explore AI training</a>
      </div>
      <dl class="proof-strip" aria-label="Clay Duncan event highlights">
        <div>
          <dt>{upcomingEvents.length}</dt>
          <dd>upcoming AI trainings listed</dd>
        </div>
        <div>
          <dt>{pastEvents.length}</dt>
          <dd>recent AI training recaps</dd>
        </div>
        <div>
          <dt>Skool</dt>
          <dd>future learning hub planned through Princeton</dd>
        </div>
      </dl>
    </div>
    <div class="hero-media va-hero-media">
      <img
        src="/images/clay-duncan-wbackground-1400.jpg"
        width="1400"
        height="787"
        alt="Clay Duncan, AI training instructor for REALTORS and mortgage professionals"
      />
      <div class="va-visual-card va-visual-card-top">
        <span>AI Training</span>
        <strong>Live events, office sessions, webinars, and recaps</strong>
      </div>
    </div>
  </section>

  <section class="section-band section-band-light upcoming-events-section" aria-labelledby="upcoming-heading">
    <div class="section-inner upcoming-events-inner">
      <div>
        <p class="eyebrow">Upcoming</p>
        <h2 id="upcoming-heading">REALTOR®-focused AI events.</h2>
        <p>
          Clay teaches two types of trainings. The first is an entry-level
          fundamentals course called The AI Success System. It covers the
          foundations of getting started with a large language model, including
          the differences between chats, projects, custom GPTs, and artifacts,
          plus setting up preferences with custom instructions and rules to
          begin daily workflows.
        </p>
        <p>
          The second type is the pocket presentation. These are one-topic,
          one-specific-task presentations built to perform a focused workflow,
          such as creating a relocation package or preparing a listing
          presentation.
        </p>
      </div>
      <div class="event-stack" aria-label="Upcoming events">
        {
          upcomingEvents.map((event) => (
            <article class="event-card event-card-featured event-card-upcoming" id={event.date}>
              <div class="event-card-title">
                <p>{event.audience}</p>
                <h3>{event.title}</h3>
                <div class="event-card-action">
                  {event.registrationUrl ? (
                    <a href={event.registrationUrl} target="_blank" rel="noopener noreferrer">
                      Register for webinar
                    </a>
                  ) : (
                    <span class="event-status">
                      {event.registrationText ?? 'Registration details coming'}
                    </span>
                  )}
                </div>
              </div>
              <dl>
                <div>
                  <dt>Date</dt>
                  <dd>{formatDate(event.date)}</dd>
                </div>
                {event.displayTime && (
                  <div>
                    <dt>Time</dt>
                    <dd>{event.displayTime}</dd>
                  </div>
                )}
                <div>
                  <dt>Location</dt>
                  <dd>{event.location}</dd>
                </div>
              </dl>
              <div class="event-card-summary">
                <p>{event.summary}</p>
                {
                  event.takeaways && (
                    <ul class="event-takeaways">
                      {event.takeaways.map((takeaway) => (
                        <li>{takeaway}</li>
                      ))}
                    </ul>
                  )
                }
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band-light" aria-labelledby="past-events-heading">
    <div class="section-inner">
      <div class="section-heading section-heading-wide">
        <div>
          <p class="eyebrow">AI Training Recaps</p>
          <h2 id="past-events-heading">Recent Training Recaps.</h2>
        </div>
      </div>
      <div class="event-grid" aria-label="Past AI training events">
        {
          pastEvents.map((event) => (
            <article class="event-card" id={event.date}>
              <p>{event.audience}</p>
              <h3>{event.title}</h3>
              <dl>
                <div>
                  <dt>Date</dt>
                  <dd>{formatDate(event.date)}</dd>
                </div>
                <div>
                  <dt>Location</dt>
                  <dd>{event.location}</dd>
                </div>
              </dl>
              <p>{event.summary}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band-dark" aria-labelledby="host-heading">
    <div class="section-inner event-host-panel">
      <div>
        <p class="eyebrow">Host a Session</p>
        <h2 id="host-heading">Bring practical AI training to your office or group.</h2>
      </div>
      <aside>
        <p>
          If you want Clay to lead a session for your team, office, association,
          or partner group, the next step is a simple conversation about
          audience, topic, timing, and format.
        </p>
        <div class="signal-list" aria-label="Session planning details">
          <span>Audience</span>
          <span>Topic</span>
          <span>Timing</span>
          <span>Format</span>
        </div>
        <div class="host-action-row">
          <a class="button button-primary" href={site.schedulingUrl}>Chat with Clay</a>
          <a class="button button-secondary" href={site.phoneHref}>Call Clay</a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
