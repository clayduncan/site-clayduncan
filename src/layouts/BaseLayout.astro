---
import globalStyles from '../styles/global.css?inline';
import { compliance } from '../data/compliance';
import { profileLinks, site } from '../data/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogType?: 'website' | 'article';
  robots?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  twitterTitle?: string;
}

const { title, description, canonical, ogTitle, ogType = 'website', robots, schema, twitterTitle } =
  Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const schemaItems = Array.isArray(schema) ? schema : schema ? [schema] : [];
const socialTitle = ogTitle ?? title;
const xTitle = twitterTitle ?? socialTitle;
const currentPath = Astro.url.pathname;
const navItems = [
  {
    label: 'Mortgage',
    href: '/huntsville/mortgage-guidance/',
    isActive:
      currentPath.startsWith('/huntsville/') || currentPath.startsWith('/resources/'),
  },
  {
    label: 'AI Training',
    href: '/realtor-ai-training/',
    isActive: currentPath.startsWith('/realtor-ai-training/'),
  },
  {
    label: 'Events',
    href: '/events/',
    isActive: currentPath.startsWith('/events/'),
  },
  {
    label: 'About',
    href: '/about/',
    isActive: currentPath.startsWith('/about/'),
  },
  {
    label: 'Reviews',
    href: '/reviews/',
    isActive: currentPath.startsWith('/reviews/'),
  },
  {
    label: 'Blog',
    href: '/blog/',
    isActive: currentPath.startsWith('/blog/'),
  },
  {
    label: 'Join Us',
    href: '/join-us/',
    isActive: currentPath.startsWith('/join-us/'),
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="msvalidate.01" content="1C808764522F73EA7E2768040CAA3069" />
    <!-- Google tag (gtag.js) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-1BR97EBZEN');

      function loadGA() {
        if (window.gaLoaded) {
          return;
        }
        window.gaLoaded = true;

        var script = document.createElement('script');
        script.async = true;
        script.src = 'https://www.googletagmanager.com/gtag/js?id=G-1BR97EBZEN';
        document.head.appendChild(script);
      }

      setTimeout(loadGA, 3000);

      ['scroll', 'mousemove', 'touchstart', 'keydown'].forEach(function (eventName) {
        window.addEventListener(eventName, loadGA, { once: true, passive: true });
      });
    </script>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      href="/fonts/inter/Inter-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/source-serif-4/SourceSerif4-800.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{title}</title>
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Clay Duncan" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={xTitle} />
    <meta name="twitter:description" content={description} />
    {
      schemaItems.map((schemaItem) => (
        <script type="application/ld+json" set:html={JSON.stringify(schemaItem)} />
      ))
    }
    <slot name="schema" />
    <style set:html={globalStyles}></style>
  </head>
  <body>
    <header class="site-header" aria-label="Site header">
      <div class="site-header-inner">
        <a class="site-logo" href="/" aria-label="Clay Duncan home">
          <img src="/favicon.svg" width="40" height="40" alt="" aria-hidden="true" />
          <span>
            <strong>Clay Duncan</strong>
            <small>{site.tagline}</small>
          </span>
        </a>
        <div class="team-brand" aria-label="Duncan Mortgage Group powered by Princeton Mortgage">
          <strong>Duncan Mortgage Group</strong>
          <small>Powered by Princeton Mortgage</small>
        </div>
        <nav class="site-nav" aria-label="Primary navigation">
          {
            navItems.map((item) => (
              <a
                class:list={{ 'nav-active': item.isActive }}
                href={item.href}
                aria-current={item.isActive ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer-inner">
        <div class="footer-contact">
          <p>
            {compliance.individualNmls.name}, {compliance.individualNmls.title},
            <a href={compliance.individualNmls.url} rel="noopener noreferrer" target="_blank">
              NMLS #{compliance.individualNmls.id}
            </a>
          </p>
          <p>
            <a href={site.phoneHref}>{site.phone}</a> &middot;
            <a href={site.emailHref}>{site.email}</a>
          </p>
        </div>
        <div class="footer-links">
          <nav class="social-links" aria-label="Social profiles">
            {
              profileLinks.map((link) => (
                <a href={link.url} rel="me noopener noreferrer" target="_blank">
                  {link.label}
                </a>
              ))
            }
          </nav>
          <p>&copy; {new Date().getFullYear()} Clay Duncan.</p>
        </div>
        <div class="site-disclosure">
          <p>
            {compliance.companyNmls.name},
            <a href={compliance.companyNmls.url} rel="noopener noreferrer" target="_blank">
              NMLS #{compliance.companyNmls.id}
            </a>.
          </p>
          <p>{compliance.equalHousing}</p>
        </div>
      </div>
    </footer>
  </body>
</html>
